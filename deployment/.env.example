# Dokus Deployment Environment Configuration
# Copy this file to .env: cp .env.example .env
#
# Goal: keep only critical secrets in env for the MVP.
# Non-secret defaults live in the service `application-*.conf` files.

# ============================================================================
# REQUIRED - Secrets (auto-generated by ./dokus.sh setup)
# ============================================================================
DB_PASSWORD=
REDIS_PASSWORD=
MINIO_PASSWORD=
JWT_SECRET=

# ============================================================================
# REQUIRED - Peppol E-Invoicing (Recommand)
# ============================================================================
# API credentials for Peppol e-invoicing via Recommand.
# Get your credentials at: https://app.recommand.eu/api-keys
PEPPOL_MASTER_API_KEY=
PEPPOL_MASTER_API_SECRET=

# ============================================================================
# REQUIRED - Transactional Email (Resend)
# ============================================================================
# Used for transactional emails:
# welcome, password reset, and notifications.
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=
# Welcome email sender identity (displayed as From header)
EMAIL_WELCOME_FROM_ADDRESS=
# Welcome email reply-to mailbox (must be monitored)
EMAIL_WELCOME_REPLY_TO_ADDRESS=

# ============================================================================
# OPTIONAL - Storage public URL (for presigned URLs accessible from clients)
# ============================================================================
# Cloud: https://your-domain.com/storage
# Self-hosted: http://<your-server-ip>:8000/storage
# STORAGE_PUBLIC_URL=

# ============================================================================
# OPTIONAL - External API Keys
# ============================================================================
# CBE API for Belgian company lookups (https://cbeapi.be)
# Default is already set in application.conf - only override if needed
# CBE_API_SECRET=

# Serper API key for website discovery enrichment
# Get key from: https://serper.dev/
# SERPER_API_KEY=

# ============================================================================
# OPTIONAL - AI Configuration (IntelligenceMode)
# ============================================================================
# Intelligence mode is the single source of truth for model selection and processing:
# - assisted:   Raspberry Pi / edge (≤16GB RAM) - single-pass extraction, no parallelism
# - autonomous: MacBook Pro M4 Max (36-48GB RAM) - sequential ensemble, validation and retries
# - sovereign:  Mac Studio M4 Max (≥128GB RAM) - parallel agents, deep self-correction
# DOKUS_INTELLIGENCE_MODE=autonomous

# Ollama host URL (defaults differ by profile)
# OLLAMA_HOST=http://localhost:11434

# ============================================================================
# OPTIONAL - Langfuse Observability
# ============================================================================
# Self-hosted Langfuse for AI pipeline observability.
# Enable by including docker-compose.langfuse.yml in your compose command.
# Auto-generated by ./dokus.sh setup if Langfuse is enabled.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_ENCRYPTION_KEY=
# LANGFUSE_SALT=
# LANGFUSE_DB_PASSWORD=
# LANGFUSE_CLICKHOUSE_PASSWORD=
# LANGFUSE_REDIS_PASSWORD=
# LANGFUSE_MINIO_PASSWORD=
# LANGFUSE_INIT_EMAIL=admin@dokus.tech
# LANGFUSE_INIT_PASSWORD=

# ============================================================================
# OPTIONAL - Cloud profile (HTTPS)
# ============================================================================
# DOMAIN=dokus.invoid.vision
# ACME_EMAIL=contact@dokus.tech
